{
  "name": "property-walkthrough",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ss -tln 2>/dev/null | grep -q ':3000 ' && (echo 'Port 3000 already in use. Another dev server is running. Kill it first:  lsof -ti:3000 | xargs kill' && exit 1) || next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@clerk/nextjs": "^6.0.0",
    "@contently/videojs-annotation-comments": "^2.0.1",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.7",
    "next": "^14.2.15",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "stripe": "^22.1.1",
    "svix": "^1.93.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.0",
    "video.js": "^7.21.7",
    "zod": "^3.23.8"
  },
