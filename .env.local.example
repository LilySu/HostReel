# Clerk — get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/properties
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/properties

# Database — Supabase Postgres
# Use the Transaction-pooler URL (port 6543) from Supabase dashboard
# (Project Settings → Database → Connection string → "Transaction" tab).
# URL-encode any special characters in the password (e.g. '@' → '%40').
# `?pgbouncer=true` is fine; the migrate script swaps port 6543 → 5432 and
# strips the flag automatically when connecting via the direct pooler port.
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Storage — 'local' (default, dev) or 'r2' (production)
STORAGE_PROVIDER=local

# LocalStorageProvider — uploads under STORAGE_DIR; URLs go through
# /api/media/[...path]. The HMAC secret for presigned upload tokens defaults
# to a per-process random value; set explicitly to keep tokens valid across
# restarts.
STORAGE_DIR=./storage
# LOCAL_UPLOAD_SECRET=

# R2StorageProvider — required only when STORAGE_PROVIDER=r2. Create two
# buckets in Cloudflare R2 (dev + prod), enable public access, and add a CORS
# policy allowing PUT/GET/HEAD from your app origin.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# App
PUBLIC_BASE_URL=http://localhost:3000

# Limits
MAX_VIDEO_DURATION_SECONDS=300
MAX_VIDEO_FILE_MB=500
MAX_PHOTO_FILE_MB=5

# Billing — Stripe + Clerk webhooks. Leaving these blank disables the video
# quota gate (useful for local dev). When set, signups get a 14-day trial via
# the Clerk user.created webhook, and Stripe webhooks update plan state.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# Stays — verified guest check-in. Without RESEND_API_KEY, invitation links
# are logged to the server console + returned in the API response (dev only).
# AUDIT_HMAC_KEY is the HMAC secret for the audit hash on each Stay; without
# it the lib falls back to a per-process random key with a loud warning.
# Generate via: openssl rand -base64 48
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@example.com
AUDIT_HMAC_KEY=
